{
  "name": "web-scrape-crawl",
  "private": true,
  "workspaces": [
    "extension",
    "site"
  ],
  "scripts": {
    "dev:ext": "npm run dev --workspace=extension",
    "dev:site": "npm run dev --workspace=site",
